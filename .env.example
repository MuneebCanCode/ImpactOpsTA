# ---------------------------------------------------------------------------
# Admin Organization Dashboard - Frontend environment variables
# ---------------------------------------------------------------------------
# Copy this file to `.env` (or `.env.local`) and fill in the values from your
# Supabase project settings. NEVER commit a file that contains real values.
#
# Only the PUBLIC anon key belongs in the frontend bundle. The Supabase
# service-role key MUST NOT appear here or in any client-side env file; it is
# configured exclusively as an Edge Function secret on the server.
#
# Use separate Supabase projects/keys for development and production
# (Requirement 13.5): point `.env` at the dev project locally and configure the
# production values in the production deployment environment.
# ---------------------------------------------------------------------------

# Base URL of your Supabase project, e.g. https://your-project-ref.supabase.co
VITE_SUPABASE_URL=

# Supabase public anon key (safe to expose in the client bundle).
# Find it under: Supabase Dashboard > Project Settings > API > Project API keys.
VITE_SUPABASE_ANON_KEY=
